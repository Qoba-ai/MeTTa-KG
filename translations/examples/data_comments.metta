(json 410 (proposal_id "4657"))
(json 410 (content "Today, we will be presenting our pitch to showcase our project in detail. It&rsquo;s at 18:00 UTC, and we hope to see you there!<a href=https://singularitynet.zoom.us/j/81403488379 rel=nofollow ugc>https://singularitynet.zoom.us/j/81403488379</a>"))
