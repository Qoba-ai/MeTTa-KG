(json 17 (title "MUSEVERSE: Music into the metaverse"))
(json 17 (content "<p data-slate-node="element"><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">Play, jam, and perform music in the metaverse. </span></span><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">Our vision is to build AI tools for composing and performing music in the backend on SingularityNET.</span></span><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">We want to create an AI for analyzing musical instruments from physical space and projecting them into virtual reality. </span></span><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">This provides an immersive experience of bridging reality with virtual reality in music production. </span></span><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">As the first musical instrument, we have chosen a </span></span><span data-slate-node="text"><span class="undefined" data-slate-leaf="true"><strong>piano keyboard</strong></span></span><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">. </span></span><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">Once we have this technology ready, we want to integrate it into these metaverses.</span></span><span data-slate-node="text"><span class="undefined" data-slate-leaf="true"> </span></span></p>
<ul>
	<li data-slate-node="element"><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">Somnium Space</span></span></li>
	<li data-slate-node="element"><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">Victoria VR</span></span></li>
	<li data-slate-node="element"><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">Decentraland</span></span></li>
	<li data-slate-node="element"><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">Sandbox </span></span></li>
	<li data-slate-node="element" data-slate-fragment=""><span data-slate-node="text"><span class="undefined" data-slate-leaf="true">SophiaVerse</span></span></li>
</ul>"))
(json 17 (link "https://deepfunding.ai/proposal/museverse-music-into-the-metaverse/"))
(json 17 (feature_image "https://deepfunding.ai/wp-content/uploads/2022/05/Screenshot-2022-05-04-at-15.16.58.png"))
