(json 113 (title "A Trust and Reputation framework for AIs"))
(json 113 (content "<p>Without a verifiable proof of Reputation of third party AI services, everyone in the SingularityNet ecosystem (users, programs, and AIs) is at the mercy of using the service of bad agents. This proposal is for the development of an open-source decentralised Identity Agent to manage AI's Reputation. Built upon a Digital Identity Trust Framework, it will enable authorised issuers and verifiers to act as the guardians of truth via the issuance of Digital Identities and Verifiable Credentials.</p>"))
(json 113 (link "https://deepfunding.ai/proposal/ai-digital-identity/"))
(json 113 (feature_image "https://deepfunding.ai/wp-content/uploads/2024/04/624513a8bb3ddf34c1fb362cb14f36b3_deepfund-1.png"))
(json 113 (requested_amount "50000"))
(json 113 (awarded_amount "50000"))
