(json 117 (title "AI-Based Impact Organization Detector"))
(json 117 (content "<p>Many people, such as impact investors, purpose-driven job seekers, and socially conscious consumers, need to differentiate between impact organizations and other organizations. However, existing platforms do not provide this distinction, which means we have to manually analyze each organization to determine if it is an impact organization. To address this, we propose building an AI system that automates this process. We will train the model using a dataset of over 24,000 existing impact organizations.</p>"))
(json 117 (link "https://deepfunding.ai/proposal/ai-based-impact-organization-detector/"))
(json 117 (feature_image "https://deepfunding.ai/wp-content/uploads/2024/01/1e0f70d69988025ac63b6c8183cd1a90_deepfund-1.png"))
